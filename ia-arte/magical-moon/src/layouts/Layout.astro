---
import Navbar from '../components/Navbar.vue';
import Footer from '../components/Footer.vue';
import SnowAnimation from '../components/SnowAnimation.vue';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Museo Fragmentos - Museo Digital de Arte', description = 'Museo digital donde cada obra, título, artista o museo son fragmentos compartidos por personas que quieren difundir el arte' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <!-- Snow Animation Background -->
    <SnowAnimation client:load />
    
    <!-- Navbar -->
    <Navbar client:load />
    
    <!-- Main Content -->
    <main class="min-h-screen pt-16 md:pt-20">
      <slot />
    </main>
    
    <!-- Footer -->
    <Footer client:load />
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #FFFFFF;
    --color-primary-dark: #F5F5F5;
    --color-primary-light: #FAFAFA;
    --color-secondary: #722F37;
    --color-accent: #F5E6D3;
    --color-wine: #722F37;
    --color-dark: #1a1a1a;
    --color-bg: #FFFFFF;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: #FFFFFF;
    color: #1f2937;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .container {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  @media (min-width: 640px) {
    .container {
      max-width: 640px;
    }
  }

  @media (min-width: 768px) {
    .container {
      max-width: 768px;
    }
  }

  @media (min-width: 1024px) {
    .container {
      max-width: 1024px;
    }
  }

  @media (min-width: 1280px) {
    .container {
      max-width: 1280px;
    }
  }

  @media (min-width: 1536px) {
    .container {
      max-width: 1536px;
    }
  }
</style>
