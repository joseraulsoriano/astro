---
import { ref } from 'vue';
import DescriptionCard from './DescriptionCard.vue';
import SnowAnimation from './SnowAnimation.vue';
import { coverAt } from '../data/museumCollection';

const images = [
  {
    src: coverAt(0),
    alt: 'Noche estrellada (referencia histórica)',
    title: 'Cielo sobre el pueblo',
    description: 'Primera pieza de una tríada curada: constelación ficticia y trazo real.',
  },
  {
    src: coverAt(13),
    alt: 'Interior de galería contemporánea',
    title: 'Pasillo de luz',
    description: 'Contraste entre volumen arquitectónico y la quietud de los marcos.',
  },
  {
    src: coverAt(27),
    alt: 'Detalle de obra abstracta',
    title: 'Temperatura del color',
    description: 'Estudio de superficie donde el accidente químico del pigmento manda.',
  },
];

const selectedImage = ref(null);
---

<html>
  <head>
    <title>Galería de Obras</title>
  </head>
  <body class="bg-gray-900 text-white">
    <div id="app" class="p-4">
      <SnowAnimation />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div
          v-for="(image, index) in images"
          :key="index"
          class="cursor-pointer"
          @click="selectedImage.value = image"
        >
          <img
            :src="image.src"
            :alt="image.alt"
            class="w-full object-contain"
          />
        </div>
      </div>

      <DescriptionCard
        v-if="selectedImage.value"
        :title="selectedImage.value.title"
        :description="selectedImage.value.description"
        @close="selectedImage.value = null"
      />
    </div>
  </body>
</html>
