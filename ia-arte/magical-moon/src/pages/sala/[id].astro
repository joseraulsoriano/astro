---
import Layout from '../../layouts/Layout.astro';
import RoomViewer from '../../components/rooms/RoomViewer.vue';

export async function getStaticPaths() {
  return ['1', '2', '3'].map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const pageTitle = `Sala virtual ${id} — Museo Fragmentos`;
const pageDescription = `Recorre esta sala virtual en Museo Fragmentos: exposiciones en 3D y obras destacadas en el museo digital.`;
---

<Layout title={pageTitle} description={pageDescription}>
  <RoomViewer client:load roomId={id} />
</Layout>
