---
import Layout from '../layouts/Layout.astro';
import SearchResults from '../components/search/SearchResults.vue';
import SearchBar from '../components/gallery/SearchBar.vue';
---

<Layout
  title="Buscar — Museo Fragmentos"
  description="Busca obras, artistas y técnicas en todo el museo digital. Resultados en tiempo real."
>
  <div class="min-h-screen bg-[#f4f7fa] pt-20">
    <!-- Header de Búsqueda -->
    <section class="border-b border-slate-200/90 bg-gradient-to-b from-sky-50/80 via-white to-[#f4f7fa] py-12">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="font-display mb-6 text-center text-4xl font-semibold tracking-tight text-slate-900 md:text-5xl">
            Buscar en Museo Fragmentos
          </h1>
          <SearchBar client:load />
        </div>
      </div>
    </section>

    <!-- Resultados -->
    <section class="py-12">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <SearchResults client:load />
      </div>
    </section>
  </div>
</Layout>

