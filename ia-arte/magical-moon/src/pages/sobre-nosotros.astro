---
import Layout from '../layouts/Layout.astro';
import TeamSection from '../components/about/TeamSection.vue';
import MissionSection from '../components/about/MissionSection.vue';
---

<Layout title="Sobre Nosotros - Museo Fragmentos">
  <div class="min-h-screen bg-white pt-20">
    <!-- Hero Section -->
    <section class="bg-gradient-to-b from-wine/5 to-white py-16 border-b border-gray-200">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">
            Sobre Nosotros
          </h1>
          <p class="text-xl md:text-2xl text-gray-700 leading-relaxed">
            Museo Fragmentos es un espacio digital donde cada obra, título, artista o museo completo 
            son fragmentos compartidos por personas que quieren difundir el arte y la cultura.
          </p>
        </div>
      </div>
    </section>

    <!-- Misión y Visión -->
    <MissionSection client:load />

    <!-- Valores -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl font-bold text-gray-900 text-center mb-12">Nuestros Valores</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="value-card text-center">
              <div class="value-icon">
                <svg class="w-12 h-12 text-wine" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Gratuito</h3>
              <p class="text-gray-600">Acceso libre y sin costos para todos los usuarios y artistas</p>
            </div>
            <div class="value-card text-center">
              <div class="value-icon">
                <svg class="w-12 h-12 text-wine" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Inclusivo</h3>
              <p class="text-gray-600">Espacio abierto para todos: artistas, museos, instituciones y público</p>
            </div>
            <div class="value-card text-center">
              <div class="value-icon">
                <svg class="w-12 h-12 text-wine" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Innovador</h3>
              <p class="text-gray-600">Tecnología de vanguardia: visualización 2D, 3D y Realidad Aumentada</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Equipo / Información Adicional -->
    <TeamSection client:load />

    <!-- Call to Action -->
    <section class="py-16 bg-gradient-to-b from-white to-wine/5">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-4xl font-bold text-gray-900 mb-6">¿Quieres ser parte de Museo Fragmentos?</h2>
          <p class="text-xl text-gray-700 mb-8">
            Únete a nuestra comunidad y comparte tu arte con el mundo
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/subir-obra" class="btn-primary">
              Subir mis obras
            </a>
            <a href="/galeria" class="btn-secondary">
              Explorar Galería
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="informacion-legal" class="py-16 bg-gray-50 border-t border-gray-200" aria-labelledby="legal-heading">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
        <h2 id="legal-heading" class="text-2xl font-bold text-gray-900 mb-4">
          Información legal
        </h2>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">
          Museo Fragmentos es una demostración de producto. Los textos, imágenes de ejemplo y flujos de autenticación
          pueden no reflejar un servicio real en producción. No se garantiza disponibilidad ni exactitud del contenido.
        </p>
        <p class="text-gray-600 text-sm leading-relaxed">
          Para términos de uso, privacidad y cookies en un despliegue real, publica aquí tus políticas definitivas
          o enlaza a documentos externos revisados por asesoría legal.
        </p>
      </div>
    </section>
  </div>
</Layout>

<style>
.value-card {
  @apply p-6;
}

.value-icon {
  @apply w-16 h-16 mx-auto mb-4 bg-wine/10 rounded-lg flex items-center justify-center;
}

.btn-primary {
  @apply inline-block px-8 py-4 bg-wine text-white font-semibold rounded-lg shadow-lg hover:bg-wine-dark transition-colors;
}

.btn-secondary {
  @apply inline-block px-8 py-4 bg-white text-wine border-2 border-wine font-semibold rounded-lg hover:bg-wine/5 transition-colors;
}
</style>

