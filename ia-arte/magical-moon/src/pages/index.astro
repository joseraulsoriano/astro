---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.vue';
import WelcomeGuide from '../components/WelcomeGuide.vue';
import FeaturesSection from '../components/sections/FeaturesSection.vue';
import RecentStrip from '../components/sections/RecentStrip.vue';
import FeaturedArtworks from '../components/sections/FeaturedArtworks.vue';
import HowItWorks from '../components/sections/HowItWorks.vue';
import CallToAction from '../components/sections/CallToAction.vue';
---

<Layout
  title="Museo Fragmentos — Museo digital de arte | Bienvenido"
  description="Explora galerías, salas virtuales en 3D y perfiles de artistas. Acceso gratis y sin registro. Sube tus obras y forma parte del museo digital."
>
  <WelcomeGuide client:load />
  <Hero client:load />
  <RecentStrip client:load />
  <FeaturesSection client:load />
  <FeaturedArtworks client:load />
  <HowItWorks client:load />
  <CallToAction client:load />
</Layout>
