---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Recuperar contraseña — Museo Fragmentos"
  description="Recuperación de cuenta en Museo Fragmentos."
  noindex
>
  <div class="min-h-screen bg-gradient-to-b from-slate-50 to-sky-50/40 pt-24 pb-16 px-4">
    <div class="max-w-md mx-auto bg-white border border-gray-200 rounded-2xl shadow-lg p-8 text-center">
      <h1 class="text-2xl font-bold text-gray-900 mb-3">Recuperar contraseña</h1>
      <p class="text-gray-600 text-sm leading-relaxed mb-6">
        En esta demostración aún no hay envío real de correos. En producción aquí iría el flujo con tu proveedor de auth (por ejemplo Supabase).
      </p>
      <a
        href="/auth/login"
        class="inline-flex items-center justify-center w-full px-4 py-3 text-sm font-semibold text-white bg-wine rounded-lg hover:bg-wine-dark transition-colors"
      >
        Volver a iniciar sesión
      </a>
      <a href="/#aviso-legal-demo" class="block mt-4 text-sm text-wine hover:text-wine-dark">
        Información legal
      </a>
    </div>
  </div>
</Layout>
