---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/gallery/GalleryGrid.vue';
import GalleryFilters from '../components/gallery/GalleryFilters.vue';
import SearchBar from '../components/gallery/SearchBar.vue';
---

<Layout
  title="Galería de arte — Museo Fragmentos"
  description="Busca y filtra obras por categoría y año. Visualización 2D, 3D y realidad aumentada. Colección en crecimiento, acceso gratuito."
>
  <div class="min-h-screen bg-museum-parchment pt-20">
    <!-- Header de la Galería -->
    <section class="relative overflow-hidden border-b border-slate-200/90 py-16 md:py-20">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_20%_0%,rgb(147_197_253_/_0.28),transparent_52%),radial-gradient(ellipse_at_80%_100%,rgb(226_232_240_/_0.75),transparent_48%)]"
      />
      <div class="container relative mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-10 text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-wine/80">
            Colección abierta
          </p>
          <h1 class="font-display text-4xl font-semibold tracking-tight text-gray-900 md:text-5xl lg:text-6xl">
            Galería de arte
          </h1>
          <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-gray-600 md:text-xl">
            Cada pieza es un fragmento curado: clásicos del dominio público, fotografía contemporánea y obras de
            estudio. Todo accesible sin registro.
          </p>
        </div>

        <!-- Barra de Búsqueda -->
        <div class="max-w-3xl mx-auto mb-8">
          <SearchBar client:load />
        </div>

        <!-- Filtros -->
        <div class="max-w-5xl mx-auto">
          <GalleryFilters client:load @filters-changed="handleFiltersChange" />
        </div>
      </div>
    </section>

    <!-- Grid de Obras -->
    <section class="py-14 md:py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <GalleryGrid client:load :filters="currentFilters" :viewMode="viewMode" />
      </div>
    </section>
  </div>
</Layout>

<script>
import { ref } from 'vue';

const viewMode = ref('grid');
const currentFilters = ref({});

const handleFiltersChange = (filters) => {
  currentFilters.value = filters;
  if (filters.viewMode) {
    viewMode.value = filters.viewMode;
  }
};
</script>

