---
import Layout from '../../layouts/Layout.astro';
import ArtworkDetail from '../../components/artwork/ArtworkDetail.vue';

export async function getStaticPaths() {
  const fromGallery = [
    'noche-estrellada',
    'obra-digital',
    'abstraccion',
    ...Array.from({ length: 20 }, (_, i) => `obra-${i + 4}`),
  ];
  const extra = ['mi-primera-obra', 'obra-en-proceso', 'girasoles', 'autorretrato'];
  const slugs = [...new Set([...fromGallery, ...extra])];
  return slugs.map((slug) => ({ params: { slug } }));
}

function slugToTitle(slug: string) {
  return slug
    .split('-')
    .filter(Boolean)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

const { slug } = Astro.params;
const label = slugToTitle(slug ?? '');
const pageTitle = `${label} — Obra | Museo Fragmentos`;
const pageDescription = `Ficha de la obra «${label}» en Museo Fragmentos: museo digital con acceso gratuito.`;
---

<Layout title={pageTitle} description={pageDescription}>
  <ArtworkDetail client:load slug={slug} />
</Layout>
