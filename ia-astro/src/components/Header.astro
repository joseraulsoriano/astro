---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "Sobre mí" },
] as const;
---

<header>
  <nav aria-label="Principal">
    <h2><a href="/">{SITE_TITLE}</a></h2>

    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle"
    />
    <label
      for="nav-toggle"
      class="nav-toggle-label"
    >
      <span class="sr-only">Abrir o cerrar menú</span>
      <span class="nav-toggle-bars" aria-hidden="true"></span>
    </label>

    <div class="nav-panel">
      <div class="internal-links">
        {navLinks.map((l) => (
          <HeaderLink href={l.href}>{l.label}</HeaderLink>
        ))}
      </div>
      <div class="social-links">
        <a href="https://github.com/joseraulsoriano" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">Perfil de GitHub</span>
          <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
            ><path
              fill="currentColor"
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path></svg
          >
        </a>
      </div>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: white;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }
  h2 {
    margin: 0;
    font-size: clamp(0.85rem, 2.5vw, 1em);
    line-height: 1.25;
    max-width: min(50vw, 14rem);
  }

  @media (min-width: 721px) {
    h2 {
      max-width: none;
    }
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    position: relative;
  }

  .nav-toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .nav-toggle:focus-visible + .nav-toggle-label {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .nav-toggle-label {
    display: none;
    cursor: pointer;
    padding: 0.75rem;
    margin: -0.5rem -0.25rem -0.5rem 0;
    border-radius: 6px;
  }

  .nav-toggle-bars {
    display: block;
    width: 1.35rem;
    height: 2px;
    background: rgb(var(--black));
    box-shadow:
      0 6px 0 rgb(var(--black)),
      0 -6px 0 rgb(var(--black));
  }

  .nav-panel {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0;
    flex: 1;
  }

  .internal-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }

  nav a {
    padding: 1em 0.5em;
    color: rgb(var(--black));
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  .social-links,
  .social-links a {
    display: flex;
  }

  @media (max-width: 720px) {
    .nav-toggle-label {
      display: block;
    }

    .nav-panel {
      display: none;
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      padding-bottom: 0.75rem;
      border-top: 1px solid rgb(var(--gray-light));
      margin-top: 0.5rem;
      padding-top: 0.5rem;
    }

    .nav-toggle:checked ~ .nav-panel {
      display: flex;
    }

    .internal-links {
      flex-direction: column;
      align-items: stretch;
    }

    .internal-links a {
      padding: 0.75rem 0.5rem;
    }

    .social-links {
      justify-content: flex-start;
      padding: 0.5rem 0.25rem 0;
    }
  }
</style>
